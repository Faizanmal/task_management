# Database (PostgreSQL)
# Update the URL below with your PostgreSQL connection string.
# Example: postgres://postgre:password@localhost:5432/mydb
DATABASE_URL="DATABASE_URL=postgresql://user:password@localhost/dbname"

# Optionally override for direct connections (e.g., when using connection pooling)
DIRECT_DATABASE_URL="postgresql://user:password@localhost/dbname"

# JWT Secrets (Change these in production!)
JWT_SECRET="your-secret-key-change-in-production"
JWT_REFRESH_SECRET="refresh-secret-key-change-in-production"

# Server Port
PORT=3001
